{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://foa-sdk.local/installer/suite-wizard/receipt.schema.json",
  "title": "FOA-SDK Suite Wizard Review Confirmation Receipt",
  "type": "object",
  "required": [
    "schema_version",
    "receipt_scope",
    "plan_sha256",
    "view_model_sha256",
    "confirmation_sha256",
    "plan",
    "view_model",
    "confirmation",
    "statement",
    "authority",
    "receipt_sha256"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": 1 },
    "receipt_scope": { "const": "review-confirmation-publication" },
    "plan_sha256": { "$ref": "#/$defs/sha256" },
    "view_model_sha256": { "$ref": "#/$defs/sha256" },
    "confirmation_sha256": { "$ref": "#/$defs/sha256" },
    "plan": { "$ref": "../Resolver/plan.schema.json" },
    "view_model": { "$ref": "../ViewModel/view-model.schema.json" },
    "confirmation": { "$ref": "../ViewModel/confirmation.schema.json" },
    "statement": {
      "const": "This receipt records a verified FOA-SDK review-only confirmation and grants no acquisition, installation, elevation, game-launch, runtime-execution, deployment, save-mutation, signing, network publication, catalog-mutation, or evidence-promotion authority."
    },
    "authority": {
      "type": "object",
      "required": [
        "acquisition",
        "installation",
        "elevation",
        "game_launch",
        "runtime_execution",
        "deployment",
        "save_mutation",
        "signing",
        "publication",
        "catalog_mutation",
        "evidence_promotion"
      ],
      "additionalProperties": false,
      "properties": {
        "acquisition": { "const": false },
        "installation": { "const": false },
        "elevation": { "const": false },
        "game_launch": { "const": false },
        "runtime_execution": { "const": false },
        "deployment": { "const": false },
        "save_mutation": { "const": false },
        "signing": { "const": false },
        "publication": { "const": false },
        "catalog_mutation": { "const": false },
        "evidence_promotion": { "const": false }
      }
    },
    "receipt_sha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
