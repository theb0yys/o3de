{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/theb0yys/FOA-SDK/blob/main/Installer/package.schema.json",
  "title": "FOA-SDK installer package manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "package_id",
    "display_name",
    "version",
    "kind",
    "status",
    "source",
    "compatibility",
    "dependencies",
    "payload",
    "lifecycle",
    "legal",
    "authority"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "schema_version": {
      "const": 1
    },
    "package_id": {
      "$ref": "#/$defs/namespaced_id"
    },
    "display_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "description": {
      "type": "string",
      "maxLength": 2048
    },
    "version": {
      "$ref": "#/$defs/semantic_version"
    },
    "kind": {
      "enum": [
        "core-foundation",
        "editor-project",
        "plugin",
        "integration",
        "runtime-adapter",
        "external-tool-provider",
        "documentation",
        "sample"
      ]
    },
    "status": {
      "enum": [
        "planned",
        "experimental",
        "preview",
        "supported",
        "deprecated",
        "blocked"
      ]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "repository",
        "commit",
        "path"
      ],
      "properties": {
        "kind": {
          "enum": [
            "product",
            "plugin",
            "reviewed-external",
            "generated"
          ]
        },
        "repository": {
          "type": "string",
          "format": "uri",
          "maxLength": 512
        },
        "commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "path": {
          "$ref": "#/$defs/relative_path"
        },
        "fingerprint_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "platforms",
        "architectures",
        "game_versions",
        "branches",
        "runtime_targets"
      ],
      "properties": {
        "platforms": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "uniqueItems": true,
          "items": {
            "enum": [
              "windows"
            ]
          }
        },
        "architectures": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "uniqueItems": true,
          "items": {
            "enum": [
              "x86_64"
            ]
          }
        },
        "game_versions": {
          "type": "array",
          "maxItems": 128,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          }
        },
        "branches": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          }
        },
        "runtime_targets": {
          "type": "array",
          "maxItems": 16,
          "uniqueItems": true,
          "items": {
            "enum": [
              "editor-only",
              "mono",
              "il2cpp",
              "runtime-neutral"
            ]
          }
        }
      }
    },
    "dependencies": {
      "type": "array",
      "maxItems": 128,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "package_id",
          "version_range",
          "required"
        ],
        "properties": {
          "package_id": {
            "$ref": "#/$defs/namespaced_id"
          },
          "version_range": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "required": {
            "type": "boolean"
          }
        }
      }
    },
    "conflicts": {
      "type": "array",
      "maxItems": 128,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/namespaced_id"
      }
    },
    "capabilities": {
      "type": "array",
      "maxItems": 128,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
        "maxLength": 128
      }
    },
    "payload": {
      "type": "array",
      "maxItems": 100000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source",
          "destination",
          "sha256",
          "size_bytes",
          "redistribution"
        ],
        "properties": {
          "source": {
            "$ref": "#/$defs/relative_path"
          },
          "destination": {
            "$ref": "#/$defs/relative_path"
          },
          "sha256": {
            "$ref": "#/$defs/sha256"
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1099511627776
          },
          "redistribution": {
            "enum": [
              "project-owned",
              "approved",
              "notice-required",
              "blocked"
            ]
          }
        }
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "install_scope",
        "elevation_required",
        "repair_supported",
        "upgrade_supported",
        "uninstall_supported",
        "rollback_required",
        "preserve_external_workspaces"
      ],
      "properties": {
        "install_scope": {
          "enum": [
            "per-user",
            "per-machine",
            "portable"
          ]
        },
        "elevation_required": {
          "type": "boolean"
        },
        "repair_supported": {
          "type": "boolean"
        },
        "upgrade_supported": {
          "type": "boolean"
        },
        "uninstall_supported": {
          "type": "boolean"
        },
        "rollback_required": {
          "type": "boolean"
        },
        "preserve_external_workspaces": {
          "const": true
        }
      }
    },
    "legal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "license_expression",
        "redistribution_review",
        "notice_files"
      ],
      "properties": {
        "license_expression": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "redistribution_review": {
          "enum": [
            "required",
            "approved",
            "blocked",
            "not-applicable"
          ]
        },
        "notice_files": {
          "type": "array",
          "maxItems": 128,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/relative_path"
          }
        }
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "game_launch",
        "runtime_execution",
        "deployment",
        "save_mutation",
        "signing",
        "publication",
        "catalog_mutation",
        "evidence_promotion"
      ],
      "properties": {
        "game_launch": {
          "const": false
        },
        "runtime_execution": {
          "const": false
        },
        "deployment": {
          "const": false
        },
        "save_mutation": {
          "const": false
        },
        "signing": {
          "const": false
        },
        "publication": {
          "const": false
        },
        "catalog_mutation": {
          "const": false
        },
        "evidence_promotion": {
          "const": false
        }
      }
    }
  },
  "$defs": {
    "semantic_version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$",
      "maxLength": 128
    },
    "namespaced_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)+$",
      "maxLength": 128
    },
    "relative_path": {
      "type": "string",
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)(?!.*//)[^\\u0000-\\u001f\\u007f]+$",
      "maxLength": 1024
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
