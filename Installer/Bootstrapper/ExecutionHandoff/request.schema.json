{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://foa-sdk.local/installer/bootstrapper/execution-handoff/request.schema.json",
  "title": "FOA-SDK Verified Receipt Package-Engine Handoff",
  "type": "object",
  "required": [
    "schema_version",
    "handoff_scope",
    "operation",
    "target_reference",
    "prior_installation_reference",
    "receipt_sha256",
    "plan_sha256",
    "view_model_sha256",
    "confirmation_sha256",
    "package_order",
    "summary",
    "required_capabilities",
    "granted_capabilities",
    "requested_by",
    "requested_at_utc",
    "receipt",
    "statement",
    "authority",
    "handoff_sha256"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": 1 },
    "handoff_scope": { "const": "verified-receipt-to-package-engine" },
    "operation": {
      "enum": ["install", "repair", "upgrade", "rollback", "uninstall"]
    },
    "target_reference": { "$ref": "#/$defs/logical_reference" },
    "prior_installation_reference": {
      "type": ["string", "null"],
      "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)+$",
      "maxLength": 128
    },
    "receipt_sha256": { "$ref": "#/$defs/sha256" },
    "plan_sha256": { "$ref": "#/$defs/sha256" },
    "view_model_sha256": { "$ref": "#/$defs/sha256" },
    "confirmation_sha256": { "$ref": "#/$defs/sha256" },
    "package_order": {
      "type": "array",
      "uniqueItems": true,
      "maxItems": 256,
      "items": { "$ref": "#/$defs/logical_reference" }
    },
    "summary": {
      "type": "object",
      "required": [
        "package_count",
        "payload_file_count",
        "payload_size_bytes"
      ],
      "additionalProperties": false,
      "properties": {
        "package_count": { "type": "integer", "minimum": 0, "maximum": 256 },
        "payload_file_count": { "type": "integer", "minimum": 0 },
        "payload_size_bytes": { "type": "integer", "minimum": 0 }
      }
    },
    "required_capabilities": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2,
      "uniqueItems": true,
      "items": {
        "enum": [
          "package-engine.execute.install",
          "package-engine.execute.repair",
          "package-engine.execute.upgrade",
          "package-engine.execute.rollback",
          "package-engine.execute.uninstall",
          "package-engine.elevation"
        ]
      }
    },
    "granted_capabilities": {
      "type": "array",
      "maxItems": 0
    },
    "requested_by": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[^\\u0000-\\u001f\\u007f]+$"
    },
    "requested_at_utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T.+Z$",
      "maxLength": 64
    },
    "receipt": {
      "$ref": "../../SuiteWizard/Receipt/receipt.schema.json"
    },
    "statement": {
      "const": "This handoff records a requested FOA-SDK package lifecycle operation bound to an exact verified review receipt. It grants no package-engine capability and performs no acquisition, installation, repair, upgrade, rollback, uninstall, elevation, game launch, runtime execution, deployment, save mutation, signing, network publication, catalog mutation, or evidence promotion."
    },
    "authority": {
      "type": "object",
      "required": [
        "acquisition",
        "installation",
        "elevation",
        "game_launch",
        "runtime_execution",
        "deployment",
        "save_mutation",
        "signing",
        "publication",
        "catalog_mutation",
        "evidence_promotion"
      ],
      "additionalProperties": false,
      "properties": {
        "acquisition": { "const": false },
        "installation": { "const": false },
        "elevation": { "const": false },
        "game_launch": { "const": false },
        "runtime_execution": { "const": false },
        "deployment": { "const": false },
        "save_mutation": { "const": false },
        "signing": { "const": false },
        "publication": { "const": false },
        "catalog_mutation": { "const": false },
        "evidence_promotion": { "const": false }
      }
    },
    "handoff_sha256": { "$ref": "#/$defs/sha256" }
  },
  "allOf": [
    {
      "if": {
        "properties": { "operation": { "const": "install" } },
        "required": ["operation"]
      },
      "then": {
        "properties": { "prior_installation_reference": { "const": null } }
      }
    },
    {
      "if": {
        "properties": {
          "operation": {
            "enum": ["repair", "upgrade", "rollback", "uninstall"]
          }
        },
        "required": ["operation"]
      },
      "then": {
        "properties": {
          "prior_installation_reference": {
            "$ref": "#/$defs/logical_reference"
          }
        }
      }
    }
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "logical_reference": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)+$",
      "maxLength": 128
    }
  }
}
