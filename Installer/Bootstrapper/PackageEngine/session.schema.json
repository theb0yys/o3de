{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://foa-sdk.local/installer/bootstrapper/package-engine/session.schema.json",
  "title": "FOA-SDK Authenticated Package Engine Session",
  "type": "object",
  "required": [
    "schema_version", "session_scope", "session_state", "session_reference",
    "handoff_sha256", "token_sha256", "token_claim_sha256", "operation_plan_sha256",
    "authority_proof_sha256", "authority_key_id", "receipt_sha256", "plan_sha256",
    "view_model_sha256", "confirmation_sha256", "operation", "target_reference",
    "prior_installation_reference", "package_order", "summary", "authorized_capabilities",
    "operation_plan", "accepted_by", "accepted_at_utc", "handoff", "capability_token",
    "token_claim", "effects", "statement", "authority", "authority_signature", "session_sha256"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": 2 },
    "session_scope": { "const": "package-engine-capability-session" },
    "session_state": { "const": "authenticated-capability-accepted-no-effects" },
    "session_reference": { "$ref": "#/$defs/reference" },
    "handoff_sha256": { "$ref": "#/$defs/sha256" },
    "token_sha256": { "$ref": "#/$defs/sha256" },
    "token_claim_sha256": { "$ref": "#/$defs/sha256" },
    "operation_plan_sha256": { "$ref": "#/$defs/sha256" },
    "authority_proof_sha256": { "$ref": "#/$defs/sha256" },
    "authority_key_id": { "$ref": "#/$defs/sha256" },
    "receipt_sha256": { "$ref": "#/$defs/sha256" },
    "plan_sha256": { "$ref": "#/$defs/sha256" },
    "view_model_sha256": { "$ref": "#/$defs/sha256" },
    "confirmation_sha256": { "$ref": "#/$defs/sha256" },
    "operation": { "enum": ["install", "repair", "upgrade", "rollback", "uninstall"] },
    "target_reference": { "$ref": "#/$defs/reference" },
    "prior_installation_reference": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/reference" }] },
    "package_order": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/reference" } },
    "summary": { "type": "object" },
    "authorized_capabilities": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
    "operation_plan": { "type": "object" },
    "accepted_by": { "type": "string", "minLength": 1, "maxLength": 160 },
    "accepted_at_utc": { "$ref": "#/$defs/utc" },
    "handoff": { "$ref": "../ExecutionHandoff/request.schema.json" },
    "capability_token": { "$ref": "token.schema.json" },
    "token_claim": { "type": "object" },
    "effects": { "type": "object" },
    "statement": { "type": "string", "minLength": 1 },
    "authority": { "type": "object" },
    "authority_signature": { "$ref": "#/$defs/sha256" },
    "session_sha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "utc": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T.+Z$", "maxLength": 64 },
    "reference": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)+$", "maxLength": 128 }
  }
}
