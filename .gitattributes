# FOA-SDK text and source-asset policy.
* text=auto eol=lf

# Windows command files retain CRLF for native tooling.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Byte-canonical project fixtures and preserved research inputs.
/Gems/TaintedGrailModdingSDK/Preview/Template/** text eol=lf
/Research/o3de-to-unity-conversion-and-runtime-bridge/inputs/FOA_SDK_O3DE_TO_UNITY_CONVERSION_AND_RUNTIME_BRIDGE_RESEARCH_REPORT.md text eol=lf

# Reviewed source assets only. Generated binaries, installers and archives are ignored.
*.png filter=lfs diff=lfs merge=lfs -text
*.ico filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.gif filter=lfs diff=lfs merge=lfs -text
*.tga filter=lfs diff=lfs merge=lfs -text
*.dds filter=lfs diff=lfs merge=lfs -text
*.fbx filter=lfs diff=lfs merge=lfs -text
*.pdf filter=lfs diff=lfs merge=lfs -text
*.ttf filter=lfs diff=lfs merge=lfs -text
*.otf filter=lfs diff=lfs merge=lfs -text
*.wav filter=lfs diff=lfs merge=lfs -text
*.mp3 filter=lfs diff=lfs merge=lfs -text

# Keep the tiny project identity assets available to source-only validation.
TaintedGrailModdingEditor/preview.png -filter -diff -merge -text
TaintedGrailModdingEditor/TaintedGrailModdingEditor.ico -filter -diff -merge -text
