{
  "$defs": {
    "id": {
      "maxLength": 128,
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$",
      "type": "string"
    },
    "ids": {
      "items": {
        "$ref": "#/$defs/id"
      },
      "maxItems": 64,
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "sha256": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "utc": {
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$",
      "type": "string"
    }
  },
  "$id": "https://github.com/theb0yys/FOA-SDK/blob/main/Plugins/RuntimeAdapters/Mono/Schemas/execution-gate.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "adapter_id": {
      "const": "adapter.foa.mono"
    },
    "authority": {
      "additionalProperties": false,
      "properties": {
        "build": {
          "const": false
        },
        "catalog_mutation": {
          "const": false
        },
        "deployment": {
          "const": false
        },
        "evidence_promotion": {
          "const": false
        },
        "game_launch": {
          "const": false
        },
        "process_execution": {
          "const": false
        },
        "publication": {
          "const": false
        },
        "runtime_execution": {
          "const": false
        },
        "runtime_mutation": {
          "const": false
        },
        "save_access": {
          "const": false
        },
        "signing": {
          "const": false
        }
      },
      "required": [
        "build",
        "deployment",
        "game_launch",
        "process_execution",
        "runtime_execution",
        "runtime_mutation",
        "save_access",
        "signing",
        "publication",
        "catalog_mutation",
        "evidence_promotion"
      ],
      "type": "object"
    },
    "binary": {
      "additionalProperties": false,
      "properties": {
        "bytes": {
          "minimum": 1,
          "type": "integer"
        },
        "relative_path": {
          "const": "FOA.SDK.RuntimeAdapter.Mono.dll"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      },
      "required": [
        "relative_path",
        "sha256",
        "bytes"
      ],
      "type": "object"
    },
    "build_plan_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "confirmation_receipt_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "execution_authorized": {
      "const": false
    },
    "expires_at_utc": {
      "$ref": "#/$defs/utc"
    },
    "gate_kind": {
      "const": "foa-mono-external-execution-gate"
    },
    "gate_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "identity_evidence_ids": {
      "$ref": "#/$defs/ids"
    },
    "install_parity_evidence_ids": {
      "$ref": "#/$defs/ids"
    },
    "package_id": {
      "const": "extension.foa-mono-runtime-adapter"
    },
    "package_version": {
      "const": "0.1.0"
    },
    "profile": {
      "additionalProperties": false,
      "properties": {
        "bepinex_version": {
          "const": "5.4.23.3"
        },
        "branch": {
          "const": "mono"
        },
        "evidence_state": {
          "const": "HostLiveLoadValidated"
        },
        "framework_version": {
          "const": "0.1.33"
        },
        "game_version": {
          "const": "1.23.401"
        },
        "profile_id": {
          "const": "foa-1.23.401-mono-bepinex5-tf-0.1.33"
        },
        "runtime_target": {
          "const": "Mono"
        },
        "unity_version": {
          "const": "6000.0.64f1"
        }
      },
      "required": [
        "profile_id",
        "game_version",
        "branch",
        "runtime_target",
        "unity_version",
        "bepinex_version",
        "framework_version",
        "evidence_state"
      ],
      "type": "object"
    },
    "ready_for_external_executor_review": {
      "const": true
    },
    "reasons": {
      "items": {
        "$ref": "#/$defs/id"
      },
      "maxItems": 32,
      "type": "array",
      "uniqueItems": true
    },
    "requested_at_utc": {
      "$ref": "#/$defs/utc"
    },
    "requested_by": {
      "$ref": "#/$defs/id"
    },
    "schema_version": {
      "const": 1
    }
  },
  "required": [
    "schema_version",
    "gate_kind",
    "adapter_id",
    "package_id",
    "package_version",
    "build_plan_sha256",
    "binary",
    "profile",
    "identity_evidence_ids",
    "install_parity_evidence_ids",
    "confirmation_receipt_sha256",
    "requested_by",
    "requested_at_utc",
    "expires_at_utc",
    "ready_for_external_executor_review",
    "execution_authorized",
    "reasons",
    "authority",
    "gate_sha256"
  ],
  "title": "FOA SDK Mono external execution gate",
  "type": "object"
}
