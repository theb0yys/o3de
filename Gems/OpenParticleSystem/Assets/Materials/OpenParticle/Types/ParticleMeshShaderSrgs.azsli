#pragma once

// Suppress DefaultDrawSrg's built-in SRG_PerDraw block; this file declares
// a custom DrawSrg containing the per-particle StructuredBuffer instead.
#define USE_CUSTOM_DRAW_SRG 1

// Pull in the standard ObjectSrg / DrawSrg / MaterialSrg / MaterialParameters
// that the StandardPBR pipeline callbacks (LightingChannels, etc.) reference
// before the material shader code is included.
#include <Atom/Feature/Common/Assets/Materials/Types/StandardPBR_Defines.azsli>

#include <OpenParticle/ParticleMeshCommon.azsli>

// Custom DrawSrg carrying the standard draw members plus the per-particle buffer.
ShaderResourceGroup DrawSrg : SRG_PerDraw
{
    uint m_uvStreamTangentBitmask;
    uint m_meshInfoIndex;

    uint GetTangentAtUv(uint uvIndex)
    {
        return (m_uvStreamTangentBitmask >> (4 * uvIndex)) & 0xF;
    }

    StructuredBuffer<ParticleMeshInstanceData> m_particleInstanceData;

    MATERIAL_PIPELINE_DRAW_SRG_MEMBERS
};
