{
    "description": "Material Type with properties used to define particle ribbon.",
    "version": 3,
    "versionUpdates": [
        {
            "toVersion": 2,
            "actions": [
                {
                    "op": "setValue",
                    "name": "blend.opacityFactor",
                    "value": 1.0
                }
            ]
        },
        {
            "toVersion": 3,
            "actions": [
                {
                    "op": "setValue",
                    "name": "general.uvOffset",
                    "value": [
                        0.0,
                        0.0
                    ]
                },
                {
                    "op": "setValue",
                    "name": "general.uvTiling",
                    "value": [
                        1.0,
                        1.0
                    ]
                }
            ]
        }
    ],
    "propertyLayout": {
        "groups": [
            {
                "name": "emissive",
                "displayName": "Emissive",
                "description": "Properties to add light emission, independent of other lights in the scene."
            },
            {
                "name": "blend",
                "displayName": "Blend Mode",
                "description": "Properties for configuring the materials transparency."
            },
            {
                "name": "general",
                "displayName": "General Settings",
                "description": "General Settings."
            }
        ],
        "properties": {
            "general": [
                {
                    "name": "DiffuseMap",
                    "displayName": "Diffuse Map",
                    "description": "Texture containing the base color for the ribbon.",
                    "type": "image",
                    "defaultValue": "Textures/OpenParticle/DefaultSpriteBaseColor.png",
                    "connection": {
                        "type": "shaderInput",
                        "name": "m_baseColorMap"
                    }
                },
                {
                    "name": "baseColorTint",
                    "displayName": "Base Color Tint",
                    "description": "Tints the base color texture and vertex color.",
                    "type": "Color",
                    "defaultValue": [
                        1.0,
                        1.0,
                        1.0
                    ],
                    "connection": {
                        "type": "ShaderInput",
                        "name": "m_baseColorTint"
                    }
                },
                {
                    "name": "doubleSided",
                    "displayName": "Double-sided",
                    "description": "Whether to render back-faces or just front-faces.",
                    "type": "Bool",
                    "defaultValue": true
                },
                {
                    "name": "uvOffset",
                    "displayName": "UV Offset",
                    "description": "Offset applied to texture UV coordinates.",
                    "type": "Vector2",
                    "defaultValue": [
                        0.0,
                        0.0
                    ],
                    "connection": {
                        "type": "ShaderInput",
                        "name": "m_uvOffset"
                    }
                },
                {
                    "name": "uvTiling",
                    "displayName": "UV Tiling",
                    "description": "Tiling (scale) applied to texture UV coordinates.",
                    "type": "Vector2",
                    "defaultValue": [
                        1.0,
                        1.0
                    ],
                    "connection": {
                        "type": "ShaderInput",
                        "name": "m_uvTiling"
                    }
                }
            ],
            "blend": [
                {
                    "name": "mode",
                    "displayName": "Blend Mode",
                    "description": "Indicates the general approach how transparency is to be applied",
                    "type": "Enum",
                    "enumValues": [
                        "Opaque",
                        "Cutout",
                        "Blended",
                        "Additive",
                        "Subtractive",
                        "Modulate"
                    ],
                    "defaultValue": "Blended",
                    "connection": {
                        "type": "shaderOption",
                        "name": "o_blendMode"
                    }
                },
                {
                    "name": "factor",
                    "displayName": "AlphaCutoff",
                    "description": "Factor for cutout threshold and blending",
                    "type": "Float",
                    "min": 0.0,
                    "max": 1.0,
                    "defaultValue": 0.5,
                    "connection": {
                        "type": "ShaderInput",
                        "name": "m_alphaCutoff"
                    }
                },
                {
                    "name": "opacityFactor",
                    "displayName": "Opacity",
                    "description": "Controls overall opacity for transparent blend modes.",
                    "type": "Float",
                    "min": 0.0,
                    "max": 1.0,
                    "defaultValue": 1.0,
                    "connection": {
                        "type": "ShaderInput",
                        "name": "m_opacityFactor"
                    }
                }
            ],
            "emissive": [
                {
                    "name": "enable",
                    "displayName": "Enable",
                    "description": "Enable the emissive group",
                    "type": "Bool",
                    "defaultValue": false
                },
                {
                    "name": "unit",
                    "displayName": "Units",
                    "description": "The photometric units of the Intensity property.",
                    "type": "Enum",
                    "enumValues": [
                        "Ev100"
                    ],
                    "defaultValue": "Ev100"
                },
                {
                    "name": "color",
                    "displayName": "Color",
                    "description": "Color is displayed as sRGB but the values are stored as linear color.",
                    "type": "Color",
                    "defaultValue": [
                        1.0,
                        1.0,
                        1.0
                    ],
                    "connection": {
                        "type": "ShaderInput",
                        "name": "m_emissiveColor"
                    }
                },
                {
                    "name": "intensity",
                    "displayName": "Intensity",
                    "description": "The amount of energy emitted.",
                    "type": "Float",
                    "defaultValue": 4,
                    "min": -10,
                    "max": 20,
                    "softMin": -6,
                    "softMax": 16
                },
                {
                    "name": "textureMap",
                    "displayName": "Texture",
                    "description": "Texture for defining emissive area.",
                    "type": "Image",
                    "connection": {
                        "type": "ShaderInput",
                        "name": "m_emissiveMap"
                    }
                },
                {
                    "name": "useTexture",
                    "displayName": "Use Texture",
                    "description": "Whether to use the texture.",
                    "type": "Bool",
                    "defaultValue": true
                },
                {
                    "name": "textureMapUv",
                    "displayName": "UV",
                    "description": "Emissive map UV set",
                    "type": "Enum",
                    "enumIsUv": true,
                    "defaultValue": "Tiled",
                    "connection": {
                        "type": "ShaderInput",
                        "name": "m_emissiveMapUvIndex"
                    }
                }
            ]
        }
    },
    "shaders": [
        {
            "file": "Shaders/OpenParticle/ParticleRibbon.shader",
            "tag": "ForwardPass"
        }
    ],
    "functors": [
        {
            "type": "ConvertEmissiveUnit",
            "args": {
                "intensityProperty": "emissive.intensity",
                "lightUnitProperty": "emissive.unit",
                "shaderInput": "m_emissiveIntensity",
                "ev100Index": 0,
                "nitIndex": 1,
                "ev100MinMax": [
                    -10,
                    20
                ],
                "nitMinMax": [
                    0.001,
                    100000.0
                ],
                "shaderParameters": [
                    {
                        "name": "m_emissiveIntensity",
                        "type": "float"
                    }
                ]
            }
        },
        {
            "type": "Lua",
            "args": {
                "file": "Shaders/OpenParticle/Particle_HandleBlendMode.lua"
            }
        },
        {
            "type": "Lua",
            "args": {
                "file": "Shaders/OpenParticle/Particle_EmissiveState.lua"
            }
        },
        {
            "type": "Lua",
            "args": {
                "file": "Materials/OpenParticle/Types/StandardPBR_HandleOpacityDoubleSided.lua"
            }
        }
    ],
    "uvNameMap": {
        "UV0": "Tiled",
        "UV1": "Unwrapped"
    }
}
