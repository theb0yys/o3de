#pragma once

#include <OpenParticle/ParticleMeshCommon.azsli>

ShaderResourceGroup DrawSrg : SRG_PerDraw
{
    uint m_uvStreamTangentBitmask;

    uint GetTangentAtUv(uint uvIndex)
    {
        return (m_uvStreamTangentBitmask >> (4 * uvIndex)) & 0xF;
    }

    StructuredBuffer<ParticleMeshInstanceData> m_particleInstanceData;
};

#include <OpenParticle/ParticleMeshHelpers.azsli>
