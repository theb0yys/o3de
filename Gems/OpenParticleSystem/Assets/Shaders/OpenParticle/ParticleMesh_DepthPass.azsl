#pragma once

#include <viewsrg_all.srgi>
#include <scenesrg_all.srgi>
#include "ParticleMeshStructuredBuffer.azsli"

#include <Atom/Features/PBR/DefaultObjectSrg.azsli>
#include <Atom/Features/InstancedTransforms.azsli>

struct VSInput
{
    float3 m_position : POSITION;
    float2 m_uv0 : UV0;
    float2 m_uv1 : UV1;
    float3 m_normal : NORMAL;
    float4 m_tangent : TANGENT;
    float3 m_bitangent : BITANGENT;
};

struct VSDepthOutput
{
    float4 m_position : SV_Position;
};

VSDepthOutput DepthPassVS(VSInput IN, uint instanceId : SV_instanceID)
{
    VSDepthOutput OUT;

    ParticleMeshInstanceData instanceData = LoadInstanceData(instanceId);
    float4x4 objectToWorld = GetObjectToWorldMatrix(instanceId);
    float3 worldPosition = ComputeParticleWorldPosition(IN.m_position, instanceData, objectToWorld);

    OUT.m_position = mul(ViewSrg::m_viewProjectionMatrix, float4(worldPosition, 1.0));

    return OUT;
}

