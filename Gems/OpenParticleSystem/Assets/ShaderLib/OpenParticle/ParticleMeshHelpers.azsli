#pragma once

ParticleMeshInstanceData LoadInstanceData(uint instanceId)
{
    ParticleMeshInstanceData d = DrawSrg::m_particleInstanceData[instanceId];

    // When the buffer is unbound (editor preview), m_hasInstanceData is 0.
    // Replace with identity transforms so the mesh renders correctly.
    if (d.m_hasInstanceData.x == 0)
    {
        d.m_offset        = float4(0, 0, 0, 0);
        d.m_color         = float4(1, 1, 1, 1);
        d.m_initRotation  = float4(0, 0, 0, 0);
        d.m_rotationQuat  = float4(0, 0, 0, 1); // identity quaternion
        d.m_scale         = float4(1, 1, 1, 0);
    }
    return d;
}

float3 ComputeParticleWorldPosition(float3 meshLocalPos, ParticleMeshInstanceData d, float4x4 objectToWorld)
{
    float3x3 initRot = AxisRadianToMatrix(d.m_initRotation);
    float3 localPos  = mul(initRot, meshLocalPos * d.m_scale.xyz);

    float4 q = d.m_rotationQuat;
    if (all(q == float4(0, 0, 0, 0)))
    {
        q = float4(0, 0, 0, 1);
    }
    localPos = mul(QuaternionToMatrix(QuatNormalize(q)), localPos);

    float3 worldPos = mul(objectToWorld, float4(localPos, 1.0)).xyz;
    return worldPos + d.m_offset.xyz;
}
